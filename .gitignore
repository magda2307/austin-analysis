# Python
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.streamlit*.log

# Virtual environments
.venv/
venv/
env/

# Local data files
data/raw/*
data/interim/*
data/processed/*
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep

# Reports generated from data
reports/figures/*
reports/tables/*
reports/metrics/*
reports/summary/*
reports/diagnostics/*
reports/metrics_*/
reports/tables_*/
!reports/figures/.gitkeep
!reports/tables/.gitkeep
!reports/metrics/.gitkeep
!reports/summary/.gitkeep
!reports/diagnostics/.gitkeep

# Generated model artifacts
models/baseline/*
models/boosting/*
models/advanced/*
models/base_*/
models/context_*/
models/smoke_*/
catboost_info/
!models/baseline/.gitkeep
!models/boosting/.gitkeep
!models/advanced/.gitkeep

# Pipeline execution artifacts (generated at runtime)
logs/
reports/run_receipts/
reports/run_receipt.json

# Scratch / temp directories (never track these)
scratch/
tmp_models/
tmp_tables/
dummy/
dummy_metrics/
metrics/
tables/
tmp.csv
dummy_data.csv
test_run.ps1
update_train_*.py
